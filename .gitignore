# Rust
/target/
**/*.rs.bk
**/*.rmeta
**/*.dSYM
**/*.dmap
**/*.o
**/*.a
**/*.so
**/*.dylib
**/*.dll
**/*.exe
**/*.pdb
**/*.lib
**/*.rlib

# Tauri
/tauri.conf.json
/.tauri/*
/src-tauri/target/
/dist/

# Node frontend (Tauri apps often use a web frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Cache and build artifacts
.cache/
.parcel-cache/
.vite/

# Environment files
.env
.env.*
!.env.example

# Editor and system files
.vscode/
.DS_Store
Thumbs.db

# Optional Rust coverage / debug artifacts
*.profraw
*.profdata

# Lockfiles
package-lock.json
yarn.lock
pnpm-lock.yaml
